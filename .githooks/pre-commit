#!/bin/sh
set -eu

# Native build: project.yml is the source of truth for the Xcode project.
# If swiftformat is installed, format the Swift sources before committing.
if command -v swiftformat >/dev/null 2>&1; then
  echo "Running swiftformat…"
  swiftformat HyperCapslock --quiet || true
  if ! git diff --quiet -- HyperCapslock; then
    echo "Swift files were reformatted. Review and stage the changes, then commit again."
    exit 1
  fi
fi
